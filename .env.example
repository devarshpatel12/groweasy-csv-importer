# Backend
PORT=4000
OPENAI_API_KEY=your-openai-api-key
# Optional: use an alternate OpenAI-compatible API base URL
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Optional secondary provider for alternate OpenAI-compatible APIs
# OPENAI_SECONDARY_API_KEY=your-secondary-api-key
# OPENAI_SECONDARY_BASE_URL=https://api.openai.com/v1
# Set to true to use the free heuristic fallback if AI calls fail.
# OPENAI_FALLBACK_MODE=true
# Optional local database file path
# DATABASE_PATH=./database.db
BATCH_SIZE=15
MAX_RETRIES=3
CORS_ORIGIN=http://localhost:3000

# Frontend (optional — defaults to http://localhost:4000)
NEXT_PUBLIC_API_URL=http://localhost:4000
